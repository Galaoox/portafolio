  <div>
    © {year} Erick Vergara // Designed for high output
  </div>
  <div class="flex gap-4 mt-4 md:mt-0">
    <span>Unit / D-01</span>
    <span>Status: Operational</span>
    <span class="text-[var(--accent-purple)] blink">/// End of line</span>
  </div>
</footer>