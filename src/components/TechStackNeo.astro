---
import { portfolioData } from '../data/portfolio';

const { skills } = portfolioData;
---

<section class="mb-20" id="tech-stack">
  <div class="flex items-end gap-4 mb-8 border-b border-[var(--border-color)] pb-4">
    <h2 class="text-3xl font-bold text-white">TECH_STACK</h2>
    <span class="text-[var(--accent-purple)] font-mono text-sm mb-1 blink">_INITIALIZING MODULES</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    {skills.map((group) => (
      <article class="bg-[var(--secondary-bg)] border border-[var(--border-color)] p-4 group hover:border-[var(--accent-purple)] transition-colors duration-300">
        <div class="flex justify-between items-start mb-4">
          <span class="text-xs text-[var(--text-muted)] tracking-widest uppercase group-hover:text-[var(--accent-purple)]">{group.name}</span>
          <span class="material-symbols-outlined text-[var(--border-color)] group-hover:text-white">{group.icon}</span>
        </div>
        <ul class="space-y-2 text-sm font-mono text-[#aaa]">
          {group.items.map((item, index) => (
            <li class="flex items-center gap-2">
              <span class:list={[
                'w-1 h-1',
                index < 3 ? 'bg-[var(--accent-purple)] shadow-[0_0_4px_var(--accent-purple)]' : 'bg-[var(--border-color)]',
              ]}></span>
              {item}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>