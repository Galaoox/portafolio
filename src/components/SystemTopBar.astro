---
const systemYear = new Date().getFullYear();
---

<div class="fixed top-0 left-0 w-full z-50 bg-[var(--primary-bg)]/90 backdrop-blur-sm border-b border-[var(--border-color)] px-4 py-2 flex justify-between items-center text-xs tracking-widest text-[var(--text-muted)]">
  <div class="flex items-center gap-4">
    <span class="text-[var(--accent-purple)]">SYS.READY</span>
    <span>// Colombia</span>
    <span class="hidden md:inline">PROTOCOL: SECURE</span>
  </div>
  <div class="flex items-center gap-4">
    <span class="text-[var(--accent-purple)] blink">• LIVE CONNECTION</span>
    <span>ID: EV-{systemYear}</span>
  </div>
</div>
